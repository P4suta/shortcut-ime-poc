<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ShortcutIme_App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:ShortcutIme_App"
    xmlns:vm="using:ShortcutIme_App.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            x:Name="StatusBlock"
            Style="{StaticResource CaptionTextBlockStyle}"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            TextWrapping="Wrap"
            Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />

        <TextBox
            Grid.Row="1"
            x:Name="InputBox"
            Header="文の読み（ローマ字／子音）　↑↓で候補選択・Enterで確定・候補ダブルクリックでも確定"
            PlaceholderText="例: kyouhaarigatougozaimasita → 今日はありがとうございました"
            IsEnabled="{x:Bind ViewModel.IsReady, Mode=OneWay}"
            TextChanged="OnInputChanged"
            KeyDown="OnInputKeyDown" />

        <ListView
            Grid.Row="2"
            x:Name="CandidateList"
            ItemsSource="{x:Bind ViewModel.Candidates, Mode=OneWay}"
            SelectedIndex="{x:Bind ViewModel.SelectedCandidateIndex, Mode=TwoWay}"
            DoubleTapped="OnCandidateInvoked"
            SelectionMode="Single"
            IsItemClickEnabled="False"
            MaxHeight="260"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="4">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:CandidateChoice">
                    <TextBlock Text="{x:Bind Display}" TextWrapping="Wrap" Padding="0,2" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Grid Grid.Row="3" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                Grid.Column="0"
                x:Name="ComposedBox"
                Header="確定文（Enter で変換を確定して追記／コピーして他アプリへ）"
                IsReadOnly="True"
                MinHeight="80"
                TextWrapping="Wrap"
                Text="{x:Bind ViewModel.ComposedText, Mode=OneWay}" />

            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Spacing="4">
                <Button Command="{x:Bind ViewModel.SendCommand}" Content="送信"
                        HorizontalAlignment="Stretch"
                        ToolTipService.ToolTip="Ctrl+Alt+Space で呼び出したアプリへ貼り付け" />
                <Button Command="{x:Bind ViewModel.CopyComposedCommand}" Content="コピー" HorizontalAlignment="Stretch" />
                <Button Command="{x:Bind ViewModel.ClearComposedCommand}" Content="クリア" HorizontalAlignment="Stretch" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
